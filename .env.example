# Nightshift Orange Pi 3B 2G configuration
NIGHTSHIFT_NODE_ID=opi3b01

# ---------------------------------------------------------------------------
# GPIO
# ---------------------------------------------------------------------------
# Light sensor (EBF26040003) is wired to Orange Pi 3B Pin 7.
# Pin 1 -> VCC, Pin 6 -> GND, Pin 7 -> digital output.
# On Orange Pi 3B Pin 7 maps to GPIO4_A4 (gpiochip4 line 4).
# Verify the chip/line mapping on the actual system with `sudo gpioinfo`.
NIGHTSHIFT_GPIO_LIGHT_CHIP=gpiochip4
NIGHTSHIFT_GPIO_LIGHT_LINE=4
NIGHTSHIFT_GPIO_LIGHT_ACTIVE_LOW=false
NIGHTSHIFT_GPIO_LIGHT_RISING_MS=1000
NIGHTSHIFT_GPIO_LIGHT_FALLING_MS=1000

# Pressure sensor is NOT wired yet. Keep enabled=false until hardware is ready.
NIGHTSHIFT_GPIO_SIT_ENABLED=false
NIGHTSHIFT_GPIO_SIT_CHIP=gpiochip0
NIGHTSHIFT_GPIO_SIT_LINE=0
NIGHTSHIFT_GPIO_SIT_ACTIVE_LOW=false
NIGHTSHIFT_GPIO_SIT_RISING_MS=150
NIGHTSHIFT_GPIO_SIT_FALLING_MS=300

NIGHTSHIFT_GPIO_STABILIZATION_MS=2000

# ---------------------------------------------------------------------------
# UART (T5-Link v1)
# ---------------------------------------------------------------------------
# Orange Pi 3B Pin 27/28/14 are wired to T5 P11.
# Pin 14 (GND)                 -> T5 P11 Pin 13 or 17 (GND)
# Pin 28 (GPIO1_A0, UART3_TX)  -> T5 P11 Pin 14 (P11, UART0_TX)
# Pin 27 (GPIO1_A1, UART3_RX)  -> T5 P11 Pin 12 (P10, UART0_RX)
#
# UART7 is disabled in the device tree to free its pins (GPIO3_C4/C5) for the
# Ethernet MDIO interface. A custom overlay enables UART3-M0 and disables
# UART7; it is referenced in /boot/extlinux/extlinux.conf. Reboot for changes
# to take effect.
NIGHTSHIFT_UART_DEVICE=/dev/ttyS3
NIGHTSHIFT_UART_BAUDRATE=460800
NIGHTSHIFT_UART_HEARTBEAT_SECONDS=2

# ---------------------------------------------------------------------------
# MQTT external interface (optional)
# ---------------------------------------------------------------------------
# MQTT is an optional external integration boundary. When disabled, GPIO,
# UART, state machine and task executor continue to run normally.
# The backend always connects to 127.0.0.1:1883 (loopback listener).
# A second listener on 192.168.50.1:1884 serves wired LAN devices (t5-device).
# Anonymous access is disabled on both listeners; credentials are required.
NIGHTSHIFT_MQTT_ENABLED=false
NIGHTSHIFT_MQTT_HOST=127.0.0.1
NIGHTSHIFT_MQTT_PORT=1883
NIGHTSHIFT_MQTT_USERNAME=nightshift-opi
NIGHTSHIFT_MQTT_PASSWORD=nightshift-opi-secret
NIGHTSHIFT_MQTT_BASE_TOPIC=nightshift/v1
NIGHTSHIFT_MQTT_KEEPALIVE=30
NIGHTSHIFT_MQTT_TLS_ENABLED=false
NIGHTSHIFT_MQTT_CA_FILE=
